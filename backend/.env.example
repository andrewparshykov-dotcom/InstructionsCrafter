# OpenAI API key — used in Phase 3 (Whisper) and Phase 5 (GPT-4o mini).
# Phase 1 does not require a real value here.
OPENAI_API_KEY=sk-replace-with-your-real-key

# Password required in every /api/generate request.
# Choose a strong random string and share it only with the intended team.
SHARED_PASSWORD=choose-a-strong-string

# Maximum accepted video size in megabytes.
MAX_VIDEO_SIZE_MB=500

# Directory for temporary files (created if missing) — used in Phase 2 onward.
TEMP_DIR=/tmp/instruction-generator

# Allowed CORS origin(s) — used in Phase 8 when the Chrome extension connects.
ALLOWED_ORIGINS=chrome-extension://replace-with-extension-id
