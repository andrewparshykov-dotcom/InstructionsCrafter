# ==========================================
# Python (backend)
# ==========================================

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# ==========================================
# Secrets & environment variables
# ==========================================

# Never commit real environment files
.env
.env.*
.envrc
.envrc.*

# But DO commit example/template files (safe to share)
!.env.example
!.env.template
!.envrc.example

# Any folder named "secrets"
secrets/

# ==========================================
# Node.js / Chrome extension (frontend)
# ==========================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Chrome extension build & signing artifacts
*.crx
*.pem

# ==========================================
# Editor / IDE settings
# ==========================================

.vscode/
.idea/
*.swp
*.swo
*~

# ==========================================
# Operating system files
# ==========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# ==========================================
# Logs & temp files
# ==========================================

*.log
tmp/
temp/

# ==========================================
# Pasted terminal output for one-off review
# ==========================================

Results in terminal.txt

# ==========================================
# Local development helpers (per-developer, may contain passwords)
# ==========================================

test_local.sh

# ==========================================
# Internal design + development notes (not published)
# ==========================================
# Kept locally for the maintainer's reference; not appropriate for the
# public fork. History before they were untracked may still show them.

ARCHITECTURE.md
CLAUDE.md
